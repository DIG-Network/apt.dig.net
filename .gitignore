# Build output (the assembled repo site) — produced by `make repo`, never committed.
/dist/
/build/

# Terraform local state + plugin cache (the .lock.hcl IS committed).
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.*
infra/*.tfplan
infra/.terraform.tfstate.lock.info

# Local GPG scratch used by tests
*.gpg-agent
/.gnupg-test/

# Accessibility test (axe via Playwright) — deps + downloaded browsers are installed
# in CI; only the source + lockfile are committed.
tests/a11y/node_modules/
tests/a11y/test-results/
tests/a11y/playwright-report/
